<% content_for :title, "Catálogo" %>
<style>
  .page-header { margin-bottom: 2rem; }
  .page-title { font-size: 22px; font-weight: 500; margin-bottom: 4px; }
  .page-sub { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .books-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }
  .book-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .book-card:hover { border-color: var(--border2); transform: translateY(-1px); }
  .book-category { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 0.3px; }
  .book-title { font-size: 15px; font-weight: 500; line-height: 1.3; color: var(--text); }
  .book-author { font-size: 12.5px; color: var(--muted); }
  .book-desc { font-size: 12.5px; color: #5c6670; line-height: 1.5; flex: 1; }
  .book-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 0.5rem; }
  .book-price { font-family: var(--mono); font-size: 14px; color: var(--green); font-weight: 500; }
  .book-rating { font-family: var(--mono); font-size: 11px; color: var(--amber); }
  .book-stock { font-family: var(--mono); font-size: 10px; color: var(--muted); }
  .empty-state { text-align: center; padding: 4rem 2rem; color: var(--muted); font-family: var(--mono); }
</style>

<div class="page-header">
  <div class="page-title">Catálogo</div>
  <div class="page-sub">// <%= @books.count %> livros disponíveis</div>
</div>

<% if @books.any? %>
  <div class="books-grid">
    <% @books.each do |book| %>
      <%= link_to book_path(book), class: "book-card" do %>
        <div class="book-category">// <%= book.category %></div>
        <div class="book-title"><%= book.title %></div>
        <div class="book-author"><%= book.author %></div>
        <div class="book-desc"><%= truncate(book.description, length: 100) %></div>
        <div class="book-footer">
          <span class="book-price">
            <% if book.price == 0 %>
              grátis
            <% else %>
              R$ <%= number_with_precision(book.price, precision: 2, delimiter: '.', separator: ',') %>
            <% end %>
          </span>
          <% rating = book.average_rating %>
          <% if rating %>
            <span class="book-rating">★ <%= rating %></span>
          <% end %>
        </div>
        <div class="book-stock">estoque: <%= book.stock %> unidades</div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <div style="font-size:2rem; margin-bottom:1rem;">📚</div>
    nenhum livro encontrado
  </div>
<% end %>
