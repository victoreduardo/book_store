<% content_for :title, @book.title %>
<style>
  .back-link { font-family: var(--mono); font-size: 12px; color: var(--muted); text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 1.5rem; }
  .back-link:hover { color: var(--text); }
  .book-layout { display: grid; grid-template-columns: 1fr 320px; gap: 2rem; align-items: start; }
  .book-main { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 2rem; }
  .book-category { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-bottom: 0.75rem; }
  .book-title { font-size: 24px; font-weight: 500; margin-bottom: 0.5rem; line-height: 1.3; }
  .book-author { font-size: 14px; color: var(--muted); margin-bottom: 1.5rem; }
  .book-desc { font-size: 14.5px; color: #9cabb8; line-height: 1.7; }
  .book-sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .sidebar-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 1.25rem; }
  .price { font-family: var(--mono); font-size: 26px; font-weight: 600; color: var(--green); margin-bottom: 1rem; }
  .btn-buy { display: block; width: 100%; background: var(--green); color: #000; border: none; border-radius: 6px; padding: 10px; font-family: var(--mono); font-size: 13px; cursor: pointer; text-align: center; text-decoration: none; }
  .btn-buy:hover { opacity: 0.85; }
  .stock-info { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-top: 8px; }
  .divider { height: 1px; background: var(--border); margin: 2rem 0; }

  .comments-section h2 { font-size: 16px; font-weight: 500; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 8px; }
  .comment-form { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 1.25rem; margin-bottom: 1.5rem; }
  .form-label { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-bottom: 6px; display: block; }
  textarea { width: 100%; background: var(--bg3); border: 1px solid var(--border2); border-radius: 6px; padding: 10px 12px; font-size: 13.5px; color: var(--text); font-family: var(--sans); resize: vertical; min-height: 80px; outline: none; }
  textarea:focus { border-color: var(--blue); }
  .rating-row { display: flex; gap: 8px; align-items: center; margin: 0.75rem 0; }
  .rating-row select { background: var(--bg3); border: 1px solid var(--border2); border-radius: 6px; padding: 5px 10px; color: var(--text); font-family: var(--mono); font-size: 12px; outline: none; }
  .btn-comment { background: var(--blue); color: #000; border: none; border-radius: 6px; padding: 8px 16px; font-family: var(--mono); font-size: 12px; cursor: pointer; margin-top: 0.5rem; }
  .btn-comment:hover { opacity: 0.85; }

  .comment-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 0.75rem; }
  .comment-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .comment-author { font-family: var(--mono); font-size: 11.5px; color: var(--blue); }
  .comment-rating { font-family: var(--mono); font-size: 11px; color: var(--amber); }
  .comment-date { font-family: var(--mono); font-size: 10px; color: var(--muted); }

  .comment-body { font-size: 13.5px; color: #9cabb8; line-height: 1.55; }
</style>

<%= link_to "← voltar ao catálogo", books_path, class: "back-link" %>

<div class="book-layout">
  <div>
    <div class="book-main">
      <div class="book-category">// <%= @book.category %></div>
      <div class="book-title"><%= @book.title %></div>
      <div class="book-author">por <%= @book.author %></div>
      <div class="book-desc"><%= @book.description %></div>
    </div>

    <div class="divider"></div>

    <div class="comments-section">
      <h2>Comentários <span style="font-family:var(--mono);font-size:13px;color:var(--muted)">(<%= @comments.count %>)</span></h2>

      <div class="comment-form">
        <%= form_with url: book_comments_path(@book), method: :post, local: true do |f| %>
          <label class="form-label">// seu comentário</label>
          <%= f.text_area :body, name: "comment[body]", placeholder: "Escreva sua opinião sobre o livro..." %>
          <div class="rating-row">
            <label class="form-label" style="margin:0">// avaliação</label>
            <select name="comment[rating]">
              <% (1..5).reverse_each do |i| %>
                <option value="<%= i %>"><%= "★" * i %> <%= i %>/5</option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="btn-comment">publicar comentário →</button>
        <% end %>
      </div>

      <% @comments.each do |comment| %>
        <div class="comment-card">
          <div class="comment-meta">
            <div>
              <span class="comment-author"><%= comment.user.name %></span>
              <span class="comment-rating" style="margin-left:8px"><%= "★" * comment.rating %></span>
            </div>
            <span class="comment-date"><%= comment.created_at.strftime("%d/%m/%Y") %></span>
          </div>
          <div class="comment-body"><%= raw(comment.body) %></div>

          <% if logged_in? %>
            <%= link_to "remover", book_comment_path(@book, comment), data: { turbo_method: :delete }, style: "font-family:var(--mono);font-size:10px;color:var(--red);text-decoration:none;float:right;margin-top:8px;" %>
          <% end %>
        </div>
      <% end %>

      <% if @comments.empty? %>
        <div style="text-align:center;padding:2rem;font-family:var(--mono);font-size:12px;color:var(--muted);">
          nenhum comentário ainda — seja o primeiro!
        </div>
      <% end %>
    </div>
  </div>

  <div class="book-sidebar">
    <div class="sidebar-card">
      <div class="price">
        <% if @book.price == 0 %>
          Grátis
        <% else %>
          R$ <%= number_with_precision(@book.price, precision: 2, delimiter: '.', separator: ',') %>
        <% end %>
      </div>
      <a href="#" class="btn-buy">Comprar agora →</a>
      <div class="stock-info">// <%= @book.stock %> unidades em estoque</div>
    </div>

    <div class="sidebar-card">
      <div style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-bottom:8px;">// detalhes</div>
      <div style="font-size:13px;color:var(--muted);display:flex;flex-direction:column;gap:6px;">
        <div><span style="color:var(--text)">Título:</span> <%= @book.title %></div>
        <div><span style="color:var(--text)">Autor:</span> <%= @book.author %></div>
        <div><span style="color:var(--text)">Categoria:</span> <%= @book.category %></div>
        <% if @book.average_rating %>
          <div><span style="color:var(--text)">Avaliação:</span> <span style="color:var(--amber)">★ <%= @book.average_rating %></span></div>
        <% end %>
      </div>
    </div>
  </div>
</div>
