<% content_for :title, "Pedido ##{@order.id}" %>
<style>
  .order-header { margin-bottom: 2rem; }
  .order-id { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-bottom: 4px; }
  .order-title { font-size: 20px; font-weight: 500; }
  .order-grid { display: grid; grid-template-columns: 1fr 300px; gap: 1.5rem; align-items: start; }
  .order-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; }
  .section-label { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 0.4px; margin-bottom: 1rem; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  .item-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 13.5px; }
  .item-row:last-child { border-bottom: none; }
  .item-title { color: var(--text); }
  .item-qty { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .item-price { font-family: var(--mono); font-size: 13px; color: var(--green); }
  .status-badge { font-family: var(--mono); font-size: 11px; padding: 3px 10px; border-radius: 20px; border: 1px solid; }
  .status-pending   { color: var(--amber); border-color: rgba(227,179,65,0.3); background: rgba(227,179,65,0.08); }
  .status-shipped   { color: var(--blue);  border-color: rgba(88,166,255,0.3);  background: rgba(88,166,255,0.07); }
  .status-delivered { color: var(--green); border-color: rgba(63,185,80,0.3);  background: rgba(63,185,80,0.07); }
  .detail-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .detail-row:last-child { border-bottom: none; }
  .detail-label { color: var(--muted); font-family: var(--mono); font-size: 11px; }
  .detail-value { color: var(--text); }
  .idor-warning {
    background: rgba(255,107,107,0.07);
    border: 1px solid rgba(255,107,107,0.2);
    border-radius: 8px;
    padding: 1rem;
    font-family: var(--mono);
    font-size: 11px;
    color: #ffa8a8;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .idor-warning strong { color: var(--red); }
</style>

<%= link_to "← meus pedidos", orders_path, class: "back-link", style: "font-family:var(--mono);font-size:12px;color:var(--muted);text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-bottom:1.5rem;" %>

<% unless @order.user == current_user %>
  <div class="idor-warning">
    <strong>Pedido de outro usuário</strong><br>
    Cliente: <strong><%= @order.user.email %></strong><br>
    Este pedido não pertence à conta atual.
  </div>
<% end %>

<div class="order-header">
  <div class="order-id">// pedido #<%= @order.id %></div>
  <div class="order-title">
    Detalhes do pedido
    <span class="status-badge status-<%= @order.status %>" style="margin-left:10px;vertical-align:middle;">
      <%= @order.status %>
    </span>
  </div>
</div>

<div class="order-grid">
  <div class="order-card">
    <div class="section-label">// itens do pedido</div>
    <% @items.each do |item| %>
      <div class="item-row">
        <div>
          <div class="item-title"><%= item.book.title %></div>
          <div class="item-qty">qty: <%= item.quantity %></div>
        </div>
        <div class="item-price">R$ <%= number_with_precision(item.price, precision: 2) %></div>
      </div>
    <% end %>
    <div style="display:flex;justify-content:space-between;margin-top:1rem;font-family:var(--mono);font-size:14px;">
      <span style="color:var(--muted)">Total</span>
      <span style="color:var(--green);font-weight:600;">R$ <%= number_with_precision(@order.total, precision: 2) %></span>
    </div>
  </div>

  <div class="order-card">
    <div class="section-label">// informações do pedido</div>
    <div class="detail-row">
      <span class="detail-label">cliente</span>
      <span class="detail-value"><%= @order.user.name %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">email</span>
      <span class="detail-value" style="color:var(--blue)"><%= @order.user.email %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">endereço</span>
      <span class="detail-value"><%= @order.address %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">cartão</span>
      <span class="detail-value" style="font-family:var(--mono)">**** **** **** <%= @order.card_last4 %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">status</span>
      <span class="detail-value"><%= @order.status %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">criado em</span>
      <span class="detail-value"><%= @order.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
</div>
